#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  ./scripts/review SOURCE_DIR DEST_DIR [extra curator args...]

Runs Curator's reviewed source-to-destination workflow. The browser review
stages SOURCE_DIR/DRYRUN.txt after Looks Good, then copies into DEST_DIR only
after Commit.

Environment overrides:
  PYTHON_BIN=/path/to/python3

Examples:
  ./scripts/review "/Volumes/mySD" "/Volumes/myHD"
EOF
}

die() {
  echo "$1" >&2
  exit "${2:-1}"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -lt 2 ]]; then
  usage >&2
  exit 64
fi

SOURCE_DIR="$1"
DEST_DIR="$2"
shift 2

if [[ ! -d "$SOURCE_DIR" ]]; then
  die "Source directory does not exist: $SOURCE_DIR" 66
fi

if [[ ! -d "$DEST_DIR" ]]; then
  die "Destination directory does not exist: $DEST_DIR" 66
fi

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEFAULT_PYTHON="$ROOT_DIR/.venv/bin/python"
PYTHON_BIN="${PYTHON_BIN:-}"

if [[ -z "$PYTHON_BIN" && -x "$DEFAULT_PYTHON" ]]; then
  PYTHON_BIN="$DEFAULT_PYTHON"
fi

if [[ -z "$PYTHON_BIN" || ! -x "$PYTHON_BIN" ]]; then
  if command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="$(command -v python3)"
  else
    die "Could not find python3. Set PYTHON_BIN=/path/to/python3 and try again." 69
  fi
fi

cd "$ROOT_DIR"
"$PYTHON_BIN" -m curator --source "$SOURCE_DIR" --dest "$DEST_DIR" "$@"
